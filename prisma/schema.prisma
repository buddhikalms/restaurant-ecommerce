generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/prisma-generated-client-v2"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
  WHOLESALE_CUSTOMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum ProductType {
  SIMPLE
  VARIABLE
}

enum VatMode {
  INCLUDED
  EXCLUDED
}

enum ShippingMethodType {
  FLAT_RATE
  FREE_SHIPPING
  LOCAL_DELIVERY
  STORE_PICKUP
  WEIGHT_BASED
  PRICE_BASED
}

enum PaymentGateway {
  STRIPE
  PAYPAL
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum CheckoutSessionStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

enum GatewayMode {
  SANDBOX
  LIVE
}

enum FoodOrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_DISPATCH
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryZoneType {
  RADIUS
  POLYGON
}

model User {
  id                String            @id @default(cuid())
  name              String
  email             String            @unique
  passwordHash      String
  phone             String?
  businessName      String?
  role              Role              @default(CUSTOMER)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  orders            Order[]
  addresses         Address[]
  deliveryAddresses DeliveryAddress[]
  checkoutSessions  CheckoutSession[]
  foodOrders        FoodOrder[]
  wholesaleProfile  WholesaleProfile?
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  sku                String           @unique
  description        String           @db.Text
  information        String?          @db.Text
  ingredients        String?          @db.Text
  nutritional        String?          @db.Text
  faq                String?          @db.Text
  imageUrl           String           @db.Text
  galleryImageUrls   Json             @default("[]")
  productType        ProductType      @default(SIMPLE)
  variantLabel       String?
  vatMode            VatMode          @default(INCLUDED)
  vatRate            Decimal          @default(20) @db.Decimal(5, 2)
  normalPrice        Decimal          @default(0) @db.Decimal(10, 2)
  wholesalePrice     Decimal          @db.Decimal(10, 2)
  weight             Decimal          @default(0) @db.Decimal(10, 2)
  requiresShipping   Boolean          @default(true)
  allowStorePickup   Boolean          @default(true)
  allowLocalDelivery Boolean          @default(true)
  stockQuantity      Int
  minOrderQuantity   Int
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  categoryId         String
  category           Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems         OrderItem[]
  variants           ProductVariant[]

  @@index([categoryId])
  @@index([name, sku])
}

model ProductVariant {
  id               String   @id @default(cuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name             String
  sku              String   @unique
  normalPrice      Decimal  @default(0) @db.Decimal(10, 2)
  wholesalePrice   Decimal  @db.Decimal(10, 2)
  stockQuantity    Int
  minOrderQuantity Int
  isActive         Boolean  @default(true)
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([productId, position])
  @@index([productId, isActive])
}

model Address {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  label        String?
  contactName  String
  businessName String?
  line1        String
  line2        String?
  city         String
  state        String
  postalCode   String
  country      String
  phone        String
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  placeId      String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]

  @@index([userId])
}

model WholesaleProfile {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName               String
  lastName                String
  mobileNumber            String
  telephoneNumber         String
  tradingName             String?
  deliveryAddressLine1    String
  deliveryAddressLine2    String?
  deliveryAddressLine3    String?
  deliveryTown            String
  deliveryPostcode        String
  differentInvoiceAddress Boolean  @default(false)
  invoiceAddressLine1     String?
  invoiceAddressLine2     String?
  invoiceAddressLine3     String?
  invoiceTown             String?
  invoicePostcode         String?
  companyType             String
  companyNumber           String?
  directorName            String?
  businessType            String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Kitchen {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  description           String?  @db.Text
  phone                 String?
  email                 String?
  addressLine1          String
  addressLine2          String?
  city                  String
  state                 String
  postalCode            String
  country               String
  latitude              Decimal  @db.Decimal(10, 7)
  longitude             Decimal  @db.Decimal(10, 7)
  maxDeliveryDistanceKm Decimal? @db.Decimal(10, 2)
  minimumOrderAmount    Decimal  @default(0) @db.Decimal(10, 2)
  deliveryFee           Decimal  @default(0) @db.Decimal(10, 2)
  freeDeliveryMinimum   Decimal? @db.Decimal(10, 2)
  preparationTimeMins   Int      @default(30)
  isActive              Boolean  @default(true)
  acceptsOrders         Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  foodItems             FoodItem[]
  deliveryZones         DeliveryZone[]
  foodOrders            FoodOrder[]

  @@index([isActive, acceptsOrders, sortOrder])
}

model FoodCategory {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  foodItems   FoodItem[]

  @@unique([name])
  @@index([isActive, sortOrder])
}

model FoodItem {
  id                  String       @id @default(cuid())
  kitchenId           String
  kitchen             Kitchen      @relation(fields: [kitchenId], references: [id], onDelete: Cascade)
  foodCategoryId      String
  foodCategory        FoodCategory @relation(fields: [foodCategoryId], references: [id], onDelete: Restrict)
  name                String
  slug                String       @unique
  shortDescription    String?
  description         String       @db.Text
  imageUrl            String       @db.Text
  price               Decimal      @db.Decimal(10, 2)
  compareAtPrice      Decimal?     @db.Decimal(10, 2)
  isAvailable         Boolean      @default(true)
  isFeatured          Boolean      @default(false)
  sortOrder           Int          @default(0)
  preparationTimeMins Int?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  orderItems          FoodOrderItem[]

  @@index([kitchenId, isAvailable, sortOrder])
  @@index([foodCategoryId, isAvailable, sortOrder])
}

model DeliveryZone {
  id                  String           @id @default(cuid())
  kitchenId           String
  kitchen             Kitchen          @relation(fields: [kitchenId], references: [id], onDelete: Cascade)
  name                String
  description         String?          @db.Text
  zoneType            DeliveryZoneType @default(RADIUS)
  centerLatitude      Decimal?         @db.Decimal(10, 7)
  centerLongitude     Decimal?         @db.Decimal(10, 7)
  radiusKm            Decimal?         @db.Decimal(10, 2)
  polygonCoordinates  Json             @default("[]")
  deliveryFee         Decimal?         @db.Decimal(10, 2)
  minimumOrderAmount  Decimal?         @db.Decimal(10, 2)
  freeDeliveryMinimum Decimal?         @db.Decimal(10, 2)
  isActive            Boolean          @default(true)
  sortOrder           Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  foodOrders          FoodOrder[]

  @@index([kitchenId, isActive, sortOrder])
  @@index([zoneType])
}

model DeliveryAddress {
  id                   String      @id @default(cuid())
  userId               String?
  user                 User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  label                String?
  recipientName        String
  phone                String
  line1                String
  line2                String?
  city                 String
  state                String
  postalCode           String
  country              String
  formattedAddress     String      @db.Text
  placeId              String?
  latitude             Decimal     @db.Decimal(10, 7)
  longitude            Decimal     @db.Decimal(10, 7)
  deliveryInstructions String?     @db.Text
  isDefault            Boolean     @default(false)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  foodOrders           FoodOrder[]

  @@index([userId, isDefault])
}

model Order {
  id                        String             @id @default(cuid())
  orderNumber               String             @unique
  userId                    String
  user                      User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  status                    OrderStatus        @default(PENDING)
  notes                     String?            @db.Text
  subtotal                  Decimal            @db.Decimal(10, 2)
  shippingCost              Decimal            @default(0) @db.Decimal(10, 2)
  handlingFee               Decimal            @default(0) @db.Decimal(10, 2)
  codFee                    Decimal            @default(0) @db.Decimal(10, 2)
  total                     Decimal            @db.Decimal(10, 2)
  itemCount                 Int
  shippingAddressId         String
  shippingAddress           Address            @relation(fields: [shippingAddressId], references: [id], onDelete: Restrict)
  shippingZoneId            String?
  shippingZone              ShippingZone?      @relation("OrderShippingZone", fields: [shippingZoneId], references: [id], onDelete: SetNull)
  shippingMethodId          String?
  shippingMethod            ShippingMethod?    @relation("OrderShippingMethod", fields: [shippingMethodId], references: [id], onDelete: SetNull)
  shippingMethodName        String?
  shippingMethodType        ShippingMethodType?
  estimatedDeliveryMinDays  Int?
  estimatedDeliveryMaxDays  Int?
  deliveryMethodDescription String?            @db.Text
  deliveryInstructions      String?            @db.Text
  paymentGateway            PaymentGateway?
  paymentMethodName         String?
  paymentStatus             PaymentStatus      @default(UNPAID)
  paymentReference          String?
  transactionId             String?
  gatewayResponseSummary    Json?
  paidAt                    DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  items                     OrderItem[]
  checkoutSession           CheckoutSession?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([shippingZoneId])
  @@index([shippingMethodId])
}

model FoodOrder {
  id                String          @id @default(cuid())
  orderNumber       String          @unique
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  kitchenId         String
  kitchen           Kitchen         @relation(fields: [kitchenId], references: [id], onDelete: Restrict)
  deliveryAddressId String
  deliveryAddress   DeliveryAddress @relation(fields: [deliveryAddressId], references: [id], onDelete: Restrict)
  deliveryZoneId    String?
  deliveryZone      DeliveryZone?   @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)
  status            FoodOrderStatus @default(PENDING)
  customerName      String
  customerEmail     String
  customerPhone     String
  notes             String?         @db.Text
  subtotal          Decimal         @db.Decimal(10, 2)
  deliveryFee       Decimal         @default(0) @db.Decimal(10, 2)
  total             Decimal         @db.Decimal(10, 2)
  itemCount         Int
  distanceKm        Decimal?        @db.Decimal(10, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  items             FoodOrderItem[]

  @@index([userId, createdAt])
  @@index([kitchenId, createdAt])
  @@index([status, createdAt])
  @@index([deliveryZoneId])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName String   @db.Text
  productSku  String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model FoodOrderItem {
  id               String    @id @default(cuid())
  foodOrderId      String
  foodOrder        FoodOrder @relation(fields: [foodOrderId], references: [id], onDelete: Cascade)
  foodItemId       String?
  foodItem         FoodItem? @relation(fields: [foodItemId], references: [id], onDelete: SetNull)
  foodItemName     String
  foodItemSlug     String
  foodCategoryName String
  quantity         Int
  unitPrice        Decimal   @db.Decimal(10, 2)
  lineTotal        Decimal   @db.Decimal(10, 2)
  selectedOptions  Json      @default("[]")
  createdAt        DateTime  @default(now())

  @@index([foodOrderId])
  @@index([foodItemId])
}

model StoreSettings {
  id                   String   @id @default("store-settings")
  deliveryNotes        String?  @db.Text
  defaultHandlingFee   Decimal  @default(0) @db.Decimal(10, 2)
  weightUnit           String   @default("kg")
  dimensionUnit        String   @default("cm")
  mapsEnabled          Boolean  @default(false)
  googleMapsApiKey     String?  @db.Text
  defaultMapLatitude   Decimal? @db.Decimal(10, 7)
  defaultMapLongitude  Decimal? @db.Decimal(10, 7)
  defaultMapZoom       Int      @default(12)
  storeLocationName    String?
  storeAddress         String?  @db.Text
  storeLatitude        Decimal? @db.Decimal(10, 7)
  storeLongitude       Decimal? @db.Decimal(10, 7)
  serviceAreaCountries Json     @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ShippingZone {
  id               String               @id @default(cuid())
  name             String
  description      String?              @db.Text
  isEnabled        Boolean              @default(true)
  sortOrder        Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  regions          ShippingZoneRegion[]
  methods          ShippingMethod[]
  orders           Order[]              @relation("OrderShippingZone")
  checkoutSessions CheckoutSession[]

  @@index([isEnabled, sortOrder])
}

model ShippingZoneRegion {
  id                String       @id @default(cuid())
  shippingZoneId    String
  shippingZone      ShippingZone @relation(fields: [shippingZoneId], references: [id], onDelete: Cascade)
  country           String?
  state             String?
  city              String?
  postalCodePattern String?
  sortOrder         Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([shippingZoneId, sortOrder])
}

model ShippingMethod {
  id                  String              @id @default(cuid())
  shippingZoneId      String
  shippingZone        ShippingZone        @relation(fields: [shippingZoneId], references: [id], onDelete: Cascade)
  name                String
  description         String?             @db.Text
  type                ShippingMethodType
  baseCost            Decimal             @default(0) @db.Decimal(10, 2)
  minimumOrderAmount  Decimal?            @db.Decimal(10, 2)
  maximumOrderAmount  Decimal?            @db.Decimal(10, 2)
  minimumWeight       Decimal?            @db.Decimal(10, 2)
  maximumWeight       Decimal?            @db.Decimal(10, 2)
  freeShippingMinimum Decimal?            @db.Decimal(10, 2)
  maximumDistanceKm   Decimal?            @db.Decimal(10, 2)
  sortOrder           Int                 @default(0)
  estimatedMinDays    Int?
  estimatedMaxDays    Int?
  instructions        String?             @db.Text
  isEnabled           Boolean             @default(true)
  codAllowed          Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  tiers               ShippingRateTier[]
  orders              Order[]             @relation("OrderShippingMethod")
  checkoutSessions    CheckoutSession[]

  @@index([shippingZoneId, isEnabled, sortOrder])
  @@index([type])
}

model ShippingRateTier {
  id               String         @id @default(cuid())
  shippingMethodId String
  shippingMethod   ShippingMethod @relation(fields: [shippingMethodId], references: [id], onDelete: Cascade)
  label            String?
  minimumValue     Decimal?       @db.Decimal(10, 2)
  maximumValue     Decimal?       @db.Decimal(10, 2)
  cost             Decimal        @default(0) @db.Decimal(10, 2)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([shippingMethodId, sortOrder])
}

model PaymentMethodSetting {
  id                         String         @id @default(cuid())
  gateway                    PaymentGateway @unique
  displayName                String
  instructions               String?        @db.Text
  isEnabled                  Boolean        @default(false)
  mode                       GatewayMode    @default(SANDBOX)
  publicKey                  String?        @db.Text
  secretKey                  String?        @db.Text
  webhookSecret              String?        @db.Text
  extraFee                   Decimal        @default(0) @db.Decimal(10, 2)
  minimumOrderAmount         Decimal?       @db.Decimal(10, 2)
  maximumOrderAmount         Decimal?       @db.Decimal(10, 2)
  allowedShippingMethodTypes Json           @default("[]")
  allowedZoneIds             Json           @default("[]")
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
}

model CheckoutSession {
  id                     String                @id @default(cuid())
  userId                 String
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                 CheckoutSessionStatus @default(PENDING)
  paymentGateway         PaymentGateway
  externalReference      String?               @unique
  checkoutPayload        Json
  gatewayResponseSummary Json?
  subtotal               Decimal               @db.Decimal(10, 2)
  shippingCost           Decimal               @default(0) @db.Decimal(10, 2)
  handlingFee            Decimal               @default(0) @db.Decimal(10, 2)
  paymentFee             Decimal               @default(0) @db.Decimal(10, 2)
  total                  Decimal               @db.Decimal(10, 2)
  shippingZoneId         String?
  shippingZone           ShippingZone?         @relation(fields: [shippingZoneId], references: [id], onDelete: SetNull)
  shippingMethodId       String?
  shippingMethod         ShippingMethod?       @relation(fields: [shippingMethodId], references: [id], onDelete: SetNull)
  orderId                String?               @unique
  order                  Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  expiresAt              DateTime
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([userId, status, createdAt])
  @@index([shippingZoneId])
  @@index([shippingMethodId])
}
